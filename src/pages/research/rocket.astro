
---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    title: 'Community-scale acoustic, ground, and structural response during rocket launches',
    status: 'Active',
    desc: 'Designing and deploying multi-sensor field measurement systems — microphones, accelerometers, and structural sensors — at community distances near Cape Canaveral to understand how launch noise affects the surrounding environment. A paper from this work is currently submitted to JASA Express Letters.',
    methods: ['Multi-sensor arrays', 'Ground vibration measurement', 'Structural response', 'NI DAQ systems'],
  },
  {
    title: 'Frequency weighting and community noise metrics for rocket launch assessment',
    status: 'Active',
    desc: 'Evaluating how standard aircraft noise metrics apply — and where they fall short — when used to assess rocket launch noise in surrounding communities. Presented at ASA Honolulu 2025.',
    methods: ['Community noise metrics', 'Frequency weighting', 'Sound pressure level predictions', 'Spaceport noise prediction'],
  },
];

const pubs = [
  {
    year: '2026',
    title: 'Community-scale measurements of acoustic, ground, and structural response during rocket launches',
    authors: 'Coyle, W.L., et al.',
    venue: 'Submitted to JASA Express Letters',
    doi: null,
    inProgress: true,
  },
  {
    year: '2026',
    title: 'Evaluating frequency weighting in community noise metrics for rocket launch assessment',
    authors: 'Coyle, W.L., Williams, H.N.*, Gee, K.L., Kellison, M.S.*, & Hart, G.W.',
    venue: 'Preparing for submission to the Journal of the Acoustical Society of America',
    doi: null,
    inProgress: true,
  },
  {
    year: '2024',
    title: 'An application of aircraft noise metrics to the Artemis-I launch.',
    authors: 'Coyle, W.L., & Gee, K.L.',
    venue: 'INTER-NOISE and NOISE-CON Congress and Conference Proceedings, 270(5)',
    doi: 'https://doi.org/10.3397/IN_2024_3712',
    inProgress: false,
  },
  {
    year: '2024',
    title: 'Aeroacoustic analysis of NASA\'s Space Launch System Artemis-I mission',
    authors: 'Kellison, M.*, Gee, K.L., Coyle, W.L.',
    venue: 'AIAA',
    doi: 'https://doi.org/10.2514/6.2024-3033',
    inProgress: false,
  },
  {
    year: '2023',
    title: 'Space Launch System acoustics: Far-field noise measurements of the Artemis-I launch',
    authors: 'Gee, K.L., Hart, G.W., Cunningham, C.F., ..., Coyle, W.L., Kellison, M.S.*, & Kuffskie, M.J.*',
    venue: 'JASA Express Letters',
    doi: 'https://doi.org/10.1121/10.0016878',
    inProgress: false,
  },

];
---

<Layout title="Rocket Acoustics — CARL Research">

  <section class="page-hero">
    <div class="container">
      <a href="/research" class="back-link">← All research areas</a>
      <div class="hero-icon">🚀</div>
      <div class="page-eyebrow">Rocket & launch acoustics</div>
      <h1 class="page-title">The sound of spaceflight</h1>
      <p class="page-sub">
        Florida's Space Coast puts us in a unique position: world-class launch
        facilities within driving distance, generating some of the most intense
        acoustic events on Earth. We measure them — at the pad, in the community,
        and everywhere in between.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 24px;">Active projects</h2>
      <div class="projects-list">
        {projects.map(p => (
          <div class="project-card">
            <div class="project-top">
              <h3 class="project-title">{p.title}</h3>
              <span class="status-badge">{p.status}</span>
            </div>
            <p class="project-desc">{p.desc}</p>
            <div class="methods">
              {p.methods.map(m => <span class="method-tag">{m}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Publications</h2>
        <a href="/publications" class="section-link">All publications →</a>
      </div>
      <div class="pubs-list">
        {pubs.map(pub => (
          <div class={`pub-card ${pub.inProgress ? 'pub-progress' : ''}`}>
            <div class="pub-year">{pub.year}</div>
            <div class="pub-body">
              <div class="pub-title">{pub.title}</div>
              <div class="pub-authors">{pub.authors}</div>
              <div class="pub-venue">{pub.inProgress ? '⟳ ' : ''}{pub.venue}</div>
            </div>
            {pub.doi
              ? <a href={pub.doi} target="_blank" class="pub-doi">DOI ↗</a>
              : <span class="pub-doi-placeholder"></span>
            }
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <div class="container cta-inner">
      <div>
        <div class="cta-title">Interested in this work?</div>
        <div class="cta-sub">Rollins undergraduates are welcome — no prior experience needed.</div>
      </div>
      <a href="/join" class="btn-gold">Join the lab</a>
    </div>
  </section>

</Layout>

<style>
  .page-hero { background: var(--navy-dark); padding: 48px 0 52px; }
  .back-link { font-size: 12px; color: rgba(255,255,255,0.45); text-decoration: none; display: inline-block; margin-bottom: 20px; transition: color 0.2s; }
  .back-link:hover { color: var(--gold); }
  .hero-icon { font-size: 36px; margin-bottom: 12px; }
  .page-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
  .page-title { font-size: 38px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
  .page-sub { font-size: 15px; color: rgba(255,255,255,0.6); max-width: 580px; line-height: 1.8; }

  .projects-list { display: flex; flex-direction: column; gap: 16px; }
  .project-card { background: var(--white); border: 0.5px solid var(--border); border-left: 4px solid var(--navy); border-radius: 0 var(--radius-lg) var(--radius-lg) 0; padding: 24px 28px; }
  .project-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; gap: 16px; }
  .project-title { font-size: 16px; font-weight: 700; color: var(--navy); line-height: 1.4; }
  .status-badge { background: #e6f7ef; color: #1a7a48; font-size: 10px; font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; padding: 3px 9px; border-radius: var(--radius-sm); flex-shrink: 0; }
  .project-desc { font-size: 13px; color: var(--text-muted); line-height: 1.75; margin-bottom: 16px; }
  .methods { display: flex; flex-wrap: wrap; gap: 8px; }
  .method-tag { background: var(--off-white); border: 0.5px solid var(--border); font-size: 11px; color: var(--navy); padding: 4px 10px; border-radius: var(--radius-sm); font-weight: 500; }

  .pubs-list { display: flex; flex-direction: column; }
  .pub-card { display: flex; align-items: flex-start; gap: 16px; padding: 16px 0; border-bottom: 0.5px solid var(--border); }
  .pub-card:last-child { border-bottom: none; }
  .pub-progress { opacity: 0.75; }
  .pub-year { font-size: 12px; font-weight: 700; color: var(--gold-muted); min-width: 38px; padding-top: 2px; }
  .pub-body { flex: 1; }
  .pub-title { font-size: 14px; font-weight: 600; color: var(--navy); margin-bottom: 3px; line-height: 1.4; }
  .pub-authors { font-size: 11px; color: var(--text-muted); margin-bottom: 3px; }
  .pub-venue { font-size: 12px; color: var(--text-muted); font-style: italic; }
  .pub-doi { font-size: 12px; font-weight: 700; color: var(--navy); flex-shrink: 0; text-decoration: none; padding-top: 2px; }
  .pub-doi:hover { color: var(--gold-muted); }
  .pub-doi-placeholder { width: 40px; flex-shrink: 0; }

  .cta-strip { background: var(--navy); padding: 32px 0; }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .cta-title { font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .cta-sub { font-size: 13px; color: rgba(255,255,255,0.55); }
</style>

<style>
  @media (max-width: 768px) {
    .page-title { font-size: 28px; }
    .project-top { flex-direction: column; gap: 8px; }
    .pub-card { flex-wrap: wrap; gap: 8px; }
    .cta-strip { padding: 28px 0; }
    .cta-inner { flex-direction: column; }
  }
</style>
