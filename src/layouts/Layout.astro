---
import '../styles/global.css';

const { title = 'CARL — Coyle Acoustics Research Lab' } = Astro.props;
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/',             label: 'Home' },
  { href: '/research',     label: 'Research' },
  { href: '/team',         label: 'Team' },
  { href: '/news',         label: 'News' },
  { href: '/publications', label: 'Publications' },
  { href: '/teaching',     label: 'Teaching' },
  { href: '/join',         label: 'Join Us' },
];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&display=swap" rel="stylesheet" />
  </head>
  <body>

    <header class="site-nav">
      <a href="/" class="nav-brand">
        <div class="nav-brand-name">CARL</div>
        <div class="nav-brand-sub">Coyle Acoustics<br/>Research Lab</div>
      </a>

      <!-- Hamburger button (mobile only) -->
      <button class="nav-hamburger" id="hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>

      <nav class="nav-links-area" id="nav-menu">
        <div class="nav-links">
          {navLinks.map(link => (
            <a href={link.href}
              class={`nav-link ${currentPath === link.href ? 'active' : ''}`}>
              {link.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <div class="wave-bar"></div>
    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <div class="footer-logo">CARL</div>
          <div class="footer-sub">
            Coyle Acoustics Research Lab<br />
            <a href="https://www.rollins.edu/physics/" target="_blank" class="footer-dept-link">
              Department of Physics · Rollins College
            </a><br />
            Winter Park, FL
          </div>
        </div>
        <div class="footer-links">
          {navLinks.map(link => (
            <a href={link.href} class="footer-link">{link.label}</a>
          ))}
        </div>
        <div class="footer-contact">
          <div class="footer-label">Dr. Whitney L. Coyle</div>
          <a href="mailto:wcoyle@rollins.edu" class="footer-email">wcoyle@rollins.edu</a>
          <div class="footer-social">
            <a href="https://www.linkedin.com/in/wcoyle/" target="_blank" class="social-link">LinkedIn</a>
            <span class="social-sep">·</span>
            <a href="https://orcid.org/0000-0002-2161-4584" target="_blank" class="social-link">ORCID</a>
            <span class="social-sep">·</span>
            <a href="https://www.rollins.edu/physics/" target="_blank" class="social-link">Rollins Physics</a>
          </div>
          <div class="footer-tagline">It's not noise. It's data.</div>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="container">
          © {new Date().getFullYear()} Coyle Acoustics Research Lab · Rollins College
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('hamburger');
      const menu = document.getElementById('nav-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('open');
        btn.classList.toggle('open');
        btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      });
      // Close menu when a link is tapped
      menu?.querySelectorAll('a').forEach(a =>
        a.addEventListener('click', () => {
          menu.classList.remove('open');
          btn?.classList.remove('open');
        })
      );
    </script>

  </body>
</html>

<style>
  /* ── NAV ── */
  .site-nav {
    display: flex;
    align-items: stretch;
    height: 62px;
    position: sticky;
    top: 0;
    z-index: 100;
    background: #111E4A;
  }

  .nav-brand {
    background: #EAA020;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 36px 0 20px;
    text-decoration: none;
    flex-shrink: 0;
    clip-path: polygon(0 0, calc(100% - 14px) 0, 100% 50%, calc(100% - 14px) 100%, 0 100%);
    transition: background 0.2s;
    z-index: 2;
  }
  .nav-brand:hover { background: #d4901a; }

  .nav-brand-name {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 26px;
    font-weight: 600;
    color: #111E4A;
    letter-spacing: 4px;
    line-height: 1;
  }
  .nav-brand-sub {
    font-size: 7.5px;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: #111E4A;
    opacity: 0.7;
    line-height: 1.5;
  }

  .nav-links-area {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 24px;
  }
  .nav-links { display: flex; gap: 20px; }
  .nav-link {
    font-size: 11px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 0.8px;
    text-transform: uppercase;
    text-decoration: none;
    padding-bottom: 3px;
    border-bottom: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }
  .nav-link:hover { color: rgba(255,255,255,0.9); }
  .nav-link.active { color: #EAA020; border-bottom-color: #EAA020; }

  /* Hamburger — hidden on desktop */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 20px;
    margin-left: auto;
    height: 100%;
  }
  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: rgba(255,255,255,0.8);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }
  .nav-hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-hamburger.open span:nth-child(2) { opacity: 0; }
  .nav-hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── FOOTER ── */
  .site-footer { background: var(--navy-dark); padding: 48px 0 0; }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
  }
  .footer-logo {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 28px; font-weight: 600; color: var(--white);
    letter-spacing: 4px; margin-bottom: 8px;
  }
  .footer-sub { font-size: 12px; color: rgba(255,255,255,0.5); line-height: 1.8; }
  .footer-dept-link { color: var(--gold); text-decoration: none; transition: opacity 0.2s; }
  .footer-dept-link:hover { opacity: 0.8; }
  .footer-links { display: flex; flex-direction: column; gap: 10px; padding-top: 4px; }
  .footer-link { font-size: 13px; color: rgba(255,255,255,0.6); transition: color 0.2s; text-decoration: none; }
  .footer-link:hover { color: var(--gold); }
  .footer-label { font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gold); margin-bottom: 8px; }
  .footer-email { font-size: 13px; color: rgba(255,255,255,0.8); display: block; margin-bottom: 12px; text-decoration: none; }
  .footer-email:hover { color: var(--gold); }
  .footer-social { display: flex; align-items: center; gap: 6px; margin-bottom: 14px; flex-wrap: wrap; }
  .social-link { font-size: 12px; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.2s; }
  .social-link:hover { color: var(--gold); }
  .social-sep { color: rgba(255,255,255,0.2); }
  .footer-tagline { font-size: 13px; font-style: italic; color: rgba(255,255,255,0.3); }
  .footer-bottom {
    border-top: 0.5px solid rgba(255,255,255,0.1);
    padding: 16px 0; font-size: 11px; color: rgba(255,255,255,0.3);
  }

  /* ── MOBILE ── */
  @media (max-width: 768px) {
    /* Nav becomes stacked */
    .site-nav {
      height: auto;
      flex-wrap: wrap;
      min-height: 58px;
    }

    .nav-brand {
      clip-path: none;
      padding: 0 20px;
      height: 58px;
    }
    .nav-brand-sub { display: none; }

    .nav-hamburger { display: flex; }

    .nav-links-area {
      display: none;
      width: 100%;
      background: #1a2855;
      padding: 16px 20px 20px;
      flex-direction: column;
      justify-content: flex-start;
    }
    .nav-links-area.open { display: flex; }

    .nav-links {
      flex-direction: column;
      gap: 0;
      width: 100%;
    }
    .nav-link {
      padding: 12px 0;
      border-bottom: 0.5px solid rgba(255,255,255,0.08);
      font-size: 13px;
      letter-spacing: 1px;
    }
    .nav-link:last-child { border-bottom: none; }

    /* Footer stacks */
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .footer-links {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px 16px;
    }
  }
</style>
