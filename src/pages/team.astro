---
import Layout from '../layouts/Layout.astro';

const pi = {
  initials: 'WC',
  name: 'Dr. Whitney L. Coyle',
  role: 'Associate Professor of Physics · Principal Investigator',
  bio: 'Ph.D. in Acoustics, Penn State (NSF Graduate Research Fellow). B.S. in Music (Clarinet) and Mathematics, Murray State. 2026 R. Bruce Lindsay Award, Acoustical Society of America. I came to physics through music — and I\'ve never left either one behind.',
  email: 'wcoyle@rollins.edu',
};

const members = [
  {
    initials: 'HW',
    name: 'Hunter',
    role: 'Graduating Senior · Team Lead',
    area: 'Rocket acoustics',
    bio: 'Hunter has been with CARL 2 years and has led field campaigns at Cape Canaveral.',
    future: 'Hunter plans to pursue a job in industry after graduation.',
  },
  {
    initials: 'NM',
    name: 'Nick',
    role: 'Undergraduate Researcher',
    area: 'Acoustics',
    bio: '[Nick joined CARL in X year and works on X. Add a sentence about his research here.]',
    future: '[Nick is interested in X after graduation. Add his goals here.]',
  },
  {
    initials: 'LM',
    name: 'Laura',
    role: 'Undergraduate Researcher',
    area: 'Acoustics',
    bio: '[Laura joined CARL in X year and works on X. Add a sentence about her research here.]',
    future: '[Laura is interested in X after graduation. Add her goals here.]',
  },
  {
    initials: 'ZM',
    name: 'Zai',
    role: 'Undergraduate Researcher',
    area: 'Acoustics',
    bio: '[Zai joined CARL in X year and works on X. Add a sentence about their research here.]',
    future: '[Zai is interested in X after graduation. Add their goals here.]',
  },
];

const alumni = [
  { name: 'Max Griffin', year: '2023–25', now: '' },
  { name: 'Makayle Kellison', year: '2022–24', now: 'Ph.D. candidate in Applied Physics, Brigham Young University' },
  { name: 'Lauren Schefter', year: '2023–25', now: 'Pursuing M.Arch., University of Virginia' },
  { name: 'Evangelina Wong', year: '2020–22', now: 'Ph.D. candidate in Medical Physics, Duke University' },
  { name: 'Connor Kaplan', year: '2020–22', now: 'Math instructor, University Instructors, Virginia' },
  { name: 'Jack Gabriel', year: '2018–21', now: 'Ph.D. in Particle Physics, College of William &amp; Mary' },
  { name: 'Camille Adkison', year: '2018–19', now: 'MS in Oceanography, Univ. of Hawaii at Monoa, Honolulu, Hawaii' },
  { name: 'James Temple', year: '2022', now: 'Database Developer, Massey Services Inc.' },
  { name: 'Carter Richard', year: '2016–18', now: '' },
  { name: 'Caitlin Richard', year: '2016', now: '' },
];
---

<Layout title="Team — CARL">

  <section class="page-hero">
    <div class="container">
      <div class="page-eyebrow">Coyle Acoustics Research Lab</div>
      <h1 class="page-title">The team</h1>
      <p class="page-sub">
        Undergraduate researchers doing real, published acoustics science at Rollins College.
        Asterisk (*) on publications denotes undergraduate co-author.
      </p>
    </div>
  </section>

  <!-- PI -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 24px;">Principal Investigator</h2>
      <div class="pi-card">
        <div class="pi-avatar">{pi.initials}</div>
        <div class="pi-info">
          <div class="pi-name">{pi.name}</div>
          <div class="pi-role">{pi.role}</div>
          <p class="pi-bio">{pi.bio}</p>
          <div class="pi-links">
            <a href={`mailto:${pi.email}`} class="btn-navy" style="margin-top: 16px;">{pi.email}</a>
            <a href="https://www.linkedin.com/in/wcoyle/" target="_blank" class="btn-outline-dark" style="margin-top: 16px;">LinkedIn ↗</a>
            <a href="https://orcid.org/0000-0002-2161-4584" target="_blank" class="btn-outline-dark" style="margin-top: 16px;">ORCID ↗</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CURRENT MEMBERS -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 8px;">Current members</h2>
      <p class="members-hint">Click any card to learn more.</p>
      <div class="member-grid">
        {members.map(m => (
          <button
            class={`member-card ${m.name.includes('Hunter') ? 'member-lead' : ''}`}
            data-name={m.name}
            data-role={m.role}
            data-area={m.area}
            data-bio={m.bio}
            data-future={m.future}
            data-initials={m.initials}
          >
            <div class="member-avatar">{m.initials}</div>
            <div class="member-name">{m.name}</div>
            <div class="member-role">{m.role}</div>
            <div class="member-area">{m.area}</div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- MODAL -->
  <div class="modal-overlay" id="modal-overlay" onclick="closeModal()">
    <div class="modal" onclick="event.stopPropagation()">
      <button class="modal-close" onclick="closeModal()">✕</button>
      <div class="modal-avatar" id="modal-initials"></div>
      <div class="modal-name" id="modal-name"></div>
      <div class="modal-role" id="modal-role"></div>
      <div class="modal-divider"></div>
      <div class="modal-label">About</div>
      <p class="modal-bio" id="modal-bio"></p>
      <div class="modal-label">Future plans</div>
      <p class="modal-future" id="modal-future"></p>
    </div>
  </div>

  <!-- ALUMNI -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 6px;">Alumni</h2>
      <p class="alumni-note">Many CARL alumni have gone on to graduate programs and careers in physics, acoustics, and engineering.</p>
      <div class="alumni-list">
        {alumni.map(a => (
          <div class="alumni-item">
            <div class="alumni-name">{a.name} <span class="alumni-year">({a.year})</span></div>
            {a.now && <div class="alumni-now">{a.now}</div>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LAB LIFE -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 6px;">Lab life</h2>
      <p class="lab-sub">Field work, launches, and life in CARL.</p>
      <div class="slider-wrap">
        <div class="slider" id="slider">
          <div class="slide active">
            <img src="/images/lab-photo-1.jpg" alt="Students deploying sensors at Cape Canaveral" class="slide-img" />
            <div class="slide-caption">Field deployment, Cape Canaveral · 2025</div>
          </div>
          <div class="slide">
            <img src="/images/lab-photo-2.jpg" alt="Lab work at Rollins" class="slide-img" />
            <div class="slide-caption">In the lab at Rollins · 2025</div>
          </div>
          <div class="slide">
            <img src="/images/lab-photo-4.jpg" alt="Lab work at Rollins" class="slide-img" />
            <div class="slide-caption">In the lab at Rollins · 2025</div>
          </div>
          <div class="slide">
            <img src="/images/lab-photo-5.jpg" alt="Lab work at Rollins" class="slide-img" />
            <div class="slide-caption">In the lab at Rollins · 2025</div>
          </div>
          <div class="slide">
            <img src="/images/lab-photo-3.jpg" alt="CARL team at a launch" class="slide-img" />
            <div class="slide-caption">Watching the launch · Cape Canaveral · 2025</div>
          </div>
        </div>
        <div class="slider-controls">
          <button class="slider-btn" id="prev" aria-label="Previous photo">←</button>
          <div class="slider-dots" id="dots">
            <button class="dot active" data-index="0"></button>
            <button class="dot" data-index="1"></button>
            <button class="dot" data-index="2"></button>
            <button class="dot" data-index="3"></button>
            <button class="dot" data-index="4"></button>
          </div>
          <button class="slider-btn" id="next" aria-label="Next photo">→</button>
        </div>
      </div>
    </div>
  </section>

</Layout>

<script>
  // Modal
  document.querySelectorAll('.member-card').forEach(card => {
    card.addEventListener('click', () => {
      document.getElementById('modal-initials').textContent = card.dataset.initials;
      document.getElementById('modal-name').textContent = card.dataset.name;
      document.getElementById('modal-role').textContent = card.dataset.role;
      document.getElementById('modal-bio').textContent = card.dataset.bio;
      document.getElementById('modal-future').textContent = card.dataset.future;
      document.getElementById('modal-overlay').classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeModal() {
    document.getElementById('modal-overlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  document.getElementById('modal-overlay')?.addEventListener('click', closeModal);
  document.querySelector('.modal-close')?.addEventListener('click', closeModal);
  document.querySelector('.modal')?.addEventListener('click', e => e.stopPropagation());
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // Slider
  const slides = document.querySelectorAll('.slide');
  const dots = document.querySelectorAll('.dot');
  let current = 0;

  function goTo(n) {
    slides[current].classList.remove('active');
    dots[current].classList.remove('active');
    current = (n + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current].classList.add('active');
  }

  document.getElementById('prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));
  setInterval(() => goTo(current + 1), 5000);
</script>

<style>
  .page-hero { background: var(--navy-dark); padding: 52px 0; }
  .page-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .page-title { font-size: 40px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
  .page-sub { font-size: 15px; color: rgba(255,255,255,0.6); max-width: 520px; line-height: 1.75; }

  .pi-card { display: flex; gap: 28px; align-items: flex-start; background: var(--white); border: 0.5px solid var(--border); border-top: 3px solid var(--gold); border-radius: var(--radius-md); padding: 28px; }
  .pi-avatar { width: 72px; height: 72px; border-radius: 50%; background: var(--navy); display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; color: var(--gold); border: 2px solid var(--gold); flex-shrink: 0; }
  .pi-name { font-size: 18px; font-weight: 700; color: var(--navy); }
  .pi-role { font-size: 12px; color: var(--text-muted); margin-top: 2px; margin-bottom: 12px; line-height: 1.6; }
  .pi-bio { font-size: 14px; color: var(--text-muted); line-height: 1.75; }
  .pi-links { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn-outline-dark {
    background: transparent; color: var(--navy);
    border: 1px solid rgba(27,45,107,0.3);
    padding: 10px 18px; border-radius: var(--radius-md);
    font-size: 13px; text-decoration: none; display: inline-block;
    transition: border-color 0.2s;
  }
  .btn-outline-dark:hover { border-color: var(--navy); }

  .members-hint { font-size: 12px; color: var(--text-muted); margin-bottom: 20px; font-style: italic; }

  .member-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .member-card {
    background: var(--white); border: 0.5px solid var(--border);
    border-radius: var(--radius-lg); padding: 22px; text-align: center;
    cursor: pointer; transition: transform 0.15s, border-color 0.15s;
    font-family: inherit; width: 100%;
  }
  .member-card:hover { transform: translateY(-2px); border-color: var(--gold); }
  .member-lead { border-top: 3px solid var(--gold); }
  .member-avatar { width: 52px; height: 52px; border-radius: 50%; background: var(--navy); display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; font-size: 14px; font-weight: 700; color: var(--gold); border: 2px solid var(--gold); }
  .member-name { font-size: 14px; font-weight: 600; color: var(--navy); }
  .member-role { font-size: 11px; color: var(--text-muted); margin-top: 3px; line-height: 1.5; }
  .member-area { font-size: 11px; color: var(--gold-muted); margin-top: 6px; font-style: italic; }

  /* MODAL */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.55); z-index: 200;
    align-items: center; justify-content: center;
    padding: 20px;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--white); border-radius: var(--radius-lg);
    padding: 36px; max-width: 420px; width: 100%;
    position: relative; text-align: center;
    border-top: 3px solid var(--gold);
  }
  .modal-close {
    position: absolute; top: 14px; right: 16px;
    background: none; border: none; font-size: 16px;
    color: var(--text-muted); cursor: pointer; line-height: 1;
  }
  .modal-close:hover { color: var(--navy); }
  .modal-avatar {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--navy); color: var(--gold);
    font-size: 16px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 14px; border: 2px solid var(--gold);
  }
  .modal-name { font-size: 20px; font-weight: 700; color: var(--navy); margin-bottom: 4px; }
  .modal-role { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
  .modal-divider { width: 40px; height: 1px; background: var(--border); margin: 16px auto; }
  .modal-label { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--gold-muted); margin-bottom: 6px; text-align: left; }
  .modal-bio { font-size: 14px; color: var(--text-muted); line-height: 1.75; margin-bottom: 20px; text-align: left; }
  .modal-future { font-size: 14px; color: var(--text-muted); line-height: 1.75; text-align: left; }

  .alumni-note { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; font-style: italic; }
  .alumni-list { display: flex; flex-direction: column; }
  .alumni-item { padding: 12px 0; border-bottom: 0.5px solid var(--border); display: flex; justify-content: space-between; align-items: center; gap: 20px; }
  .alumni-item:last-child { border-bottom: none; }
  .alumni-name { font-size: 14px; font-weight: 600; color: var(--navy); }
  .alumni-year { font-weight: 400; color: var(--text-muted); }
  .alumni-now { font-size: 13px; color: var(--text-muted); text-align: right; }

  .lab-sub { font-size: 13px; color: var(--text-muted); margin-bottom: 24px; font-style: italic; }
  .slider-wrap { max-width: 700px; margin: 0 auto; }
  .slider { position: relative; border-radius: var(--radius-lg); overflow: hidden; background: var(--navy-dark); }
  .slide { display: none; }
  .slide.active { display: block; }
  .slide-img { width: 100%; height: 420px; object-fit: cover; object-position: center; display: block; }
  .slide-caption { padding: 14px 20px; font-size: 12px; color: rgba(255,255,255,0.6); letter-spacing: 0.3px; background: var(--navy-dark); }
  .slider-controls { display: flex; align-items: center; justify-content: center; gap: 16px; margin-top: 16px; }
  .slider-btn { background: var(--white); border: 0.5px solid var(--border); color: var(--navy); font-size: 16px; font-weight: 700; width: 36px; height: 36px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s, color 0.2s; }
  .slider-btn:hover { background: var(--navy); color: var(--white); }
  .slider-dots { display: flex; gap: 8px; align-items: center; }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--border); border: none; cursor: pointer; transition: background 0.2s; padding: 0; }
  .dot.active { background: var(--gold); }

  @media (max-width: 768px) {
    .page-title { font-size: 30px; }
    .pi-card { flex-direction: column; }
    .member-grid { grid-template-columns: 1fr 1fr; }
    .alumni-item { flex-direction: column; align-items: flex-start; gap: 3px; }
    .alumni-now { text-align: left; }
    .slide-img { height: 260px; }
    .modal { padding: 28px 20px; }
  }
</style>
