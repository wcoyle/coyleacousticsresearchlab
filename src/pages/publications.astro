---
import Layout from '../layouts/Layout.astro';

// Replace with your real publications — formatted as BibTeX or manually entered
const pubs = [
  {
    year: '2026',
    title: 'Infrasound propagation from commercial launch vehicles in the near field',
    authors: 'Coyle, [et al.]',
    venue: 'Journal of the Acoustical Society of America',
    doi: '#',
  },
  {
    year: '2025',
    title: 'Passive acoustic monitoring of bottlenose dolphins in Mosquito Lagoon',
    authors: 'Coyle, [et al.]',
    venue: 'Marine Mammal Science',
    doi: '#',
  },
];

const years = [...new Set(pubs.map(p => p.year))];
---

<Layout title="Publications — CARL">

  <section class="page-hero">
    <div class="container">
      <div class="page-eyebrow">Coyle Acoustics Research Lab</div>
      <h1 class="page-title">Publications</h1>
      <p class="page-sub">Peer-reviewed papers, conference proceedings, and technical reports.</p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      {years.map(year => (
        <div class="year-group">
          <div class="year-label">{year}</div>
          {pubs.filter(p => p.year === year).map(pub => (
            <div class="pub-card">
              <div class="pub-title">{pub.title}</div>
              <div class="pub-meta">
                <span class="pub-authors">{pub.authors}</span>
                <span class="pub-sep">·</span>
                <span class="pub-venue">{pub.venue}</span>
              </div>
              <a href={pub.doi} class="pub-doi">DOI →</a>
            </div>
          ))}
        </div>
      ))}
    </div>
  </section>

</Layout>

<style>
  .page-hero { background: var(--navy-dark); padding: 52px 0; }
  .page-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .page-title { font-size: 40px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
  .page-sub { font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.75; }

  .year-group { margin-bottom: 36px; }
  .year-label { font-size: 13px; font-weight: 700; letter-spacing: 1px; color: var(--gold-muted); text-transform: uppercase; margin-bottom: 14px; border-bottom: 0.5px solid var(--border); padding-bottom: 8px; }
  .pub-card { background: var(--white); border: 0.5px solid var(--border); border-radius: var(--radius-md); padding: 20px 24px; margin-bottom: 12px; }
  .pub-title { font-size: 15px; font-weight: 600; color: var(--navy); margin-bottom: 8px; line-height: 1.45; }
  .pub-meta { font-size: 12px; color: var(--text-muted); margin-bottom: 10px; }
  .pub-sep { margin: 0 6px; }
  .pub-venue { font-style: italic; }
  .pub-doi { font-size: 12px; color: var(--navy); font-weight: 600; letter-spacing: 0.3px; }
  .pub-doi:hover { color: var(--gold-muted); }
</style>
