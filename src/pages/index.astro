---
import Layout from '../layouts/Layout.astro';

const researchAreas = [
  {
    href: '/research/rocket',
    tag: 'Rocket & launch acoustics',
    title: 'The sound of spaceflight',
    desc: 'From near-field launch noise at Cape Canaveral to infrasound measured miles away in surrounding communities, we study how rockets shake the air, and what that data means for people who live nearby.',
    icon: '🚀',
  },
  {
    href: '/research/musical',
    tag: 'Musical acoustics',
    title: 'The physics of music and instruments',
    desc: 'From clarinet mouthpiece pressure to standing waves in organ flue pipes, we investigate how instruments make sound. This work connects physics, computation, and musical performance.',
    icon: '🎵',
  },
];
---

<Layout title="CARL — Coyle Acoustics Research Lab">

  <!-- HERO: PI + Mission -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow">Rollins College · Winter Park, FL</div>
        <h1 class="hero-title">Coyle Acoustics<br/>Research Lab</h1>
<p class="hero-mission">
  Acoustics research at Rollins College, spanning rocket launch noise and musical instruments. Students don't just assist — they co-author, present, and lead.
</p>
        <p class="hero-tagline"><span class="gold">It's not noise. It's data.</span></p>
        <div class="hero-btns">
          <a href="/research" class="btn-gold">Our research</a>
          <a href="/join"     class="btn-outline">Join the lab</a>
        </div>
      </div>

      <div class="pi-card">
  <div class="pi-photo-wrap">
    <img src="/images/WCoyle_2026.JPG" alt="Dr. Whitney L. Coyle" class="pi-photo" />
  </div>
  <div class="pi-body">
    <div class="pi-name">Dr. Whitney L. Coyle</div>
<div class="pi-title">Associate Professor<br/>Chair, Department of Physics</div>
    <div class="pi-divider"></div>
    <p class="pi-bio">
      I came to physics through music — a B.S. in Clarinet and Mathematics led to an M.S. and Ph.D. in Acoustics at Penn State. Turns out clarinets and rockets have more in common than you'd think.
    </p>
    <div class="pi-links">
      <a href="mailto:wcoyle@rollins.edu" class="pi-link">Email</a>
      <span class="pi-sep">·</span>
      <a href="https://www.linkedin.com/in/wcoyle/" target="_blank" class="pi-link">LinkedIn</a>
      <span class="pi-sep">·</span>
      <a href="https://orcid.org/0000-0002-2161-4584" target="_blank" class="pi-link">ORCID</a>
    </div>
    <div class="pi-dept">
      <a href="https://www.rollins.edu/physics/" target="_blank" class="pi-dept-link">
        Dept. of Physics · Rollins College ↗
      </a>
    </div>
  </div>
</div>
  </section>

  <!-- RESEARCH AREAS -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Research areas</h2>
        <a href="/research" class="section-link">See all projects →</a>
      </div>
      <div class="research-grid">
        {researchAreas.map(area => (
          <a href={area.href} class="research-card">
            <div class="research-icon">{area.icon}</div>
            <span class="tag">{area.tag}</span>
            <h3 class="research-title">{area.title}</h3>
            <p class="research-desc">{area.desc}</p>
            <span class="research-cta">Explore →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

<!-- FEATURED IN -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Featured in</h2>
        <a href="/press" class="section-link">All coverage →</a>
      </div>
      <div class="press-grid">
        <a href="https://acousticalsociety.org/lindsay-award/" target="_blank" class="press-card">
          <div class="press-outlet">Acoustical Society of America · 2026</div>
          <div class="press-title">R. Bruce Lindsay Award — Dr. Whitney L. Coyle</div>
          <div class="press-cta">Read more ↗</div>
        </a>
        <a href="https://www.rollins.edu/college-of-liberal-arts/news/what-its-like-to-partner-with-your-professor/" target="_blank" class="press-card">
          <div class="press-outlet">Rollins College News · 2025</div>
          <div class="press-title">"What It's Like to Partner with Your Professor"</div>
          <div class="press-cta">Read article ↗</div>
        </a>
        <a href="https://www.bbc.com/future/article/20230306-just-how-loud-is-a-rocket-launch" target="_blank" class="press-card">
          <div class="press-outlet">BBC Future · 2023 · Updated 2024</div>
          <div class="press-title">"Is SpaceX's Starship the Loudest Ever Rocket?"</div>
          <div class="press-cta">Read article ↗</div>
        </a>
        <a href="https://www.cfpublic.org/podcast/are-we-there-yet/2023-02-21/measuring-the-sound-of-rockets-nsyncs-lance-bass-chronicles-the-last-soviet-in-space" target="_blank" class="press-card">
          <div class="press-outlet">Central Florida Public Media · 2023</div>
          <div class="press-title">"Measuring the Sound of Rockets" — Are We There Yet?</div>
          <div class="press-cta">Listen ↗</div>
        </a>
      </div>
    </div>
  </section>

  <!-- JOIN CTA -->
  <section class="join-cta">
    <div class="container join-inner">
      <div class="join-eyebrow">Rollins College · Liberal Arts Research</div>
      <h2 class="join-title">Interested in joining CARL?</h2>
      <p class="join-sub">
        We welcome Rollins undergraduates who are curious, motivated, and ready
        to do real science. No prior research experience required.
      </p>
      <div class="cta-btns">
        <a href="/join"         class="btn-gold">Get involved</a>
        <a href="/join#contact" class="btn-outline">Contact Dr. Coyle</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero { background: var(--navy-dark); }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.4fr 0.6fr;
    gap: 52px;
    align-items: center;
    padding-top: 60px;
    padding-bottom: 60px;
  }
  .hero-eyebrow { font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; }
  .hero-title { font-size: 40px; line-height: 1.1; color: var(--white); font-weight: 700; margin-bottom: 20px; letter-spacing: -0.5px; }
  .hero-mission { font-size: 15px; line-height: 1.8; color: rgba(255,255,255,0.65); margin-bottom: 14px; max-width: 500px; }
  .hero-tagline { font-size: 14px; font-style: italic; color: rgba(255,255,255,0.45); margin-bottom: 28px; }
  .gold { color: var(--gold); font-style: normal; font-weight: 700; }
  .hero-btns { display: flex; gap: 12px; flex-wrap: wrap; }


.pi-avatar-img {
    width: 90px; height: 90px; border-radius: 50%;
    object-fit: cover; object-position: center top;
    border: 2px solid var(--gold);
    margin: 0 auto 14px; display: block;
  }
  .pi-card {
    background: rgba(255,255,255,0.06);
    border: 0.5px solid rgba(255,255,255,0.12);
    border-top: 3px solid var(--gold);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-align: center;
  }
.pi-photo-wrap {
    width: 100%;
    height: 320px;
    overflow: hidden;
  }
  .pi-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
object-position: center 15%;
    display: block;
  }
  .pi-body { padding: 14px 18px 18px; }
  .pi-name { font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .pi-title { font-size: 10px; letter-spacing: 0.8px; text-transform: uppercase; color: var(--gold); line-height: 1.5; }
  .pi-divider { width: 40px; height: 1px; background: rgba(255,255,255,0.15); margin: 14px auto; }
  .pi-bio { font-size: 13px; line-height: 1.75; color: rgba(255,255,255,0.55); margin-bottom: 16px; font-style: italic; }
  .pi-links { display: flex; align-items: center; justify-content: center; gap: 6px; margin-bottom: 10px; flex-wrap: wrap; }
  .pi-link { font-size: 12px; color: var(--gold); text-decoration: none; transition: opacity 0.2s; }
  .pi-link:hover { opacity: 0.75; }
  .pi-sep { color: rgba(255,255,255,0.25); font-size: 11px; }
  .pi-dept { margin-top: 10px; }
  .pi-dept-link { font-size: 11px; color: rgba(255,255,255,0.4); text-decoration: none; transition: color 0.2s; }
  .pi-dept-link:hover { color: rgba(255,255,255,0.7); }

  .research-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .research-card {
    background: var(--white); border: 0.5px solid var(--border);
    border-top: 3px solid var(--navy); border-radius: var(--radius-md);
    padding: 28px; text-decoration: none; display: block;
    transition: transform 0.15s, border-top-color 0.15s;
  }
  .research-card:hover { transform: translateY(-2px); border-top-color: var(--gold); }
  .research-icon { font-size: 28px; margin-bottom: 12px; }
  .research-title { font-size: 17px; font-weight: 700; color: var(--navy); margin: 10px 0 10px; line-height: 1.35; }
  .research-desc { font-size: 13px; color: var(--text-muted); line-height: 1.7; margin-bottom: 18px; }
  .research-cta { font-size: 12px; font-weight: 700; color: var(--gold-muted); letter-spacing: 0.5px; }


  .avatar {
    width: 56px; height: 56px; border-radius: 50%;
    background: var(--navy); display: flex; align-items: center;
    justify-content: center; margin: 0 auto 12px;
    font-size: 14px; font-weight: 700; color: var(--gold);
    border: 2px solid var(--gold); transition: transform 0.2s;
  }



  .join-cta { background: var(--navy); padding: 60px 0; }
  .join-inner { text-align: center; }
  .join-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 14px; }
  .join-title { font-size: 30px; font-weight: 700; color: var(--white); margin-bottom: 10px; }
  .join-sub { font-size: 14px; color: rgba(255,255,255,0.6); margin-bottom: 28px; max-width: 480px; margin-left: auto; margin-right: auto; line-height: 1.75; }
  .cta-btns { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
</style>

<style>
  @media (max-width: 768px) {
.hero-inner {
  grid-template-columns: 1fr !important;
  padding-top: 36px;
  padding-bottom: 36px;
  gap: 24px;
}
.pi-card {
  width: 100%;
  max-width: 100%;
}
.pi-photo-wrap {
  height: 200px !important;
}
.pi-body {
  text-align: center;
}
.pi-links {
  justify-content: center;
}
    .hero-title { font-size: 30px; }
    .hero-mission { font-size: 14px; }
    .pi-card { text-align: left; }
    .pi-avatar { margin: 0 0 14px; }
.pi-photo-wrap { display: none; }
    .pi-links { justify-content: flex-start; }
    .research-grid { grid-template-columns: 1fr; }
    .join-cta { padding: 40px 0; }
    .join-title { font-size: 24px; }
    .press-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  }

</style>
