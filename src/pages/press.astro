---
import Layout from '../layouts/Layout.astro';

const international = [
  {
    outlet: 'BBC Future',
    year: '2023 · Updated 2024',
    title: 'Is SpaceX\'s Starship the loudest ever rocket?',
    desc: 'Originally covering the Artemis-I noise measurements, updated in November 2024 to include new Starship acoustic data. Features Dr. Coyle\'s Rice Krispies finding.',
    link: 'https://www.bbc.com/future/article/20230306-just-how-loud-is-a-rocket-launch',
  },
  {
    outlet: 'Space.com',
    year: '2023',
    title: 'Artemis 1 moon launch was as loud as 40 million bowls of Rice Krispies',
    desc: 'Coverage of CARL\'s Artemis-I acoustic measurements, reporting on noise levels that exceeded predictions at all five measurement stations.',
    link: 'https://www.space.com/artemis-1-sls-moon-launch-sound-levels',
  },
  {
    outlet: 'Interesting Engineering',
    year: '2023',
    title: 'Scientists compared NASA\'s SLS to a bowl of cereal — here\'s why',
    desc: 'International coverage of the Artemis-I noise study, featuring Dr. Coyle\'s comparison of SLS crackling quality to Rice Krispies.',
    link: 'https://interestingengineering.com/science/nasas-sls-compared-to-a-bowl-of-cereal',
  },
  {
    outlet: 'AIP Publishing',
    year: '2023',
    title: 'The Roar and Crackle of Artemis 1',
    desc: 'Research spotlight from the publisher of JASA Express Letters on the team\'s far-field noise measurements during the Artemis-I launch.',
    link: 'https://publishing.aip.org/publications/latest-content/the-roar-and-crackle-of-artemis-1/',
  },
];

const podcasts = [
  {
    outlet: 'Across Acoustics · Acoustical Society of America',
    year: '2023',
    title: 'How Loud is NASA\'s Space Launch System?',
    desc: 'Dr. Coyle was featured on the official ASA podcast discussing the Artemis-I noise measurements and what they reveal about rocket sound generation and propagation.',
    link: 'https://goodpods.com/podcasts/across-acoustics-230498/how-loud-is-nasas-space-launch-system-30632522',
  },
  {
    outlet: 'Central Florida Public Media · Are We There Yet?',
    year: '2023',
    title: 'Measuring the sound of rockets',
    desc: 'Dr. Coyle appeared on Central Florida Public Media\'s space podcast to discuss the Artemis-I acoustic study and what the data tells us about community noise impact.',
    link: 'https://www.cfpublic.org/podcast/are-we-there-yet/2023-02-21/measuring-the-sound-of-rockets-nsyncs-lance-bass-chronicles-the-last-soviet-in-space',
  },
];

const local = [
  {
    outlet: 'The Sandspur · Rollins College',
    year: '2026',
    title: 'Waveforms and Wavelengths: Navigating the Spectrum of Physics at Rollins',
    desc: 'Rollins\' student newspaper profiles Dr. Coyle and the CARL research program.',
    link: 'https://www.thesandspur.org/waveforms-and-wavelengths-navigating-the-spectrum-of-physics-at-rollins/',
  },
  {
    outlet: 'Rollins College News',
    year: '2025',
    title: 'What It\'s Like to Partner with Your Professor',
    desc: 'Rollins College features the CARL undergraduate research model and what students gain from working alongside Dr. Coyle.',
    link: 'https://www.rollins.edu/college-of-liberal-arts/news/what-its-like-to-partner-with-your-professor/',
  },
  {
    outlet: 'Rollins College News',
    year: '2024',
    title: 'Cool Class: Physics for Future Presidents',
    desc: 'Rollins College News spotlights Dr. Coyle\'s general education physics course connecting science to policy and public life.',
    link: 'https://www.rollins.edu/college-of-liberal-arts/news/cool-class-physics-for-future-presidents/',
  },
];
---

<Layout title="Press — CARL">

  <section class="page-hero">
    <div class="container">
      <div class="page-eyebrow">Coyle Acoustics Research Lab</div>
      <h1 class="page-title">Press &amp; media</h1>
      <p class="page-sub">
        Coverage of CARL research in international outlets, podcasts, and local media.
      </p>
    </div>
  </section>

  <!-- INTERNATIONAL -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 24px;">International coverage</h2>
      <div class="press-list">
        {international.map(item => (
          <a href={item.link} target="_blank" class="press-card">
            <div class="press-meta">
              <span class="press-outlet">{item.outlet}</span>
              <span class="press-year">{item.year}</span>
            </div>
            <div class="press-title">"{item.title}"</div>
            <p class="press-desc">{item.desc}</p>
            <span class="press-cta">Read ↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PODCASTS -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 24px;">Podcast appearances</h2>
      <div class="press-list">
        {podcasts.map(item => (
          <a href={item.link} target="_blank" class="press-card press-card-podcast">
            <div class="press-meta">
              <span class="press-outlet">{item.outlet}</span>
              <span class="press-year">{item.year}</span>
            </div>
            <div class="press-title">"{item.title}"</div>
            <p class="press-desc">{item.desc}</p>
            <span class="press-cta">Listen ↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- LOCAL / ROLLINS -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 24px;">Rollins &amp; local coverage</h2>
      <div class="press-list">
        {local.map(item => (
          <a href={item.link} target="_blank" class="press-card">
            <div class="press-meta">
              <span class="press-outlet">{item.outlet}</span>
              <span class="press-year">{item.year}</span>
            </div>
            <div class="press-title">"{item.title}"</div>
            <p class="press-desc">{item.desc}</p>
            <span class="press-cta">Read ↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero { background: var(--navy-dark); padding: 52px 0; }
  .page-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .page-title { font-size: 40px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
  .page-sub { font-size: 15px; color: rgba(255,255,255,0.6); max-width: 520px; line-height: 1.75; }

  .press-list { display: flex; flex-direction: column; gap: 14px; }
  .press-card {
    display: block; text-decoration: none;
    background: var(--white); border: 0.5px solid var(--border);
    border-left: 4px solid var(--navy);
    border-radius: 0 var(--radius-lg) var(--radius-lg) 0;
    padding: 22px 28px;
    transition: border-left-color 0.15s, transform 0.15s;
  }
  .press-card:hover { border-left-color: var(--gold); transform: translateX(3px); }
  .press-card-podcast { border-left-color: #5a2d91; }
  .press-card-podcast:hover { border-left-color: var(--gold); }

  .press-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .press-outlet { font-size: 11px; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; color: var(--gold-muted); }
  .press-year { font-size: 11px; color: var(--text-muted); }
  .press-title { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 8px; line-height: 1.4; }
  .press-desc { font-size: 13px; color: var(--text-muted); line-height: 1.7; margin-bottom: 12px; }
  .press-cta { font-size: 12px; font-weight: 700; color: var(--gold-muted); }

  @media (max-width: 768px) {
    .page-title { font-size: 30px; }
    .press-card { padding: 18px; }
    .press-meta { flex-direction: column; align-items: flex-start; gap: 4px; }
  }
</style>
