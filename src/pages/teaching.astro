---
import Layout from '../layouts/Layout.astro';

const currentCourses = [
  { code: 'PHY 130', title: 'Principles of Physics I with Lab', level: 'Introductory' },
  { code: 'PHY 131', title: 'Principles of Physics II with Lab', level: 'Introductory' },
  { code: 'PHY 308', title: 'Classical Mechanics', level: 'Advanced' },
  { code: 'HON 350S', title: 'Electricity and Making', level: 'Honors' },
  { code: 'PHY 220', title: 'Mathematical Methods I, II', level: 'Intermediate' },
  { code: 'PHY 245', title: 'Topics in Physics: Applied Electronics and Embedded Systems', level: 'Intermediate' },
];

const signatureCourses = [
  {
    code: 'rFLA 300',
    title: 'Make Some Noise',
    desc: 'An interdisciplinary general education course connecting acoustics, physics, and culture. Students explore how sound shapes human experience.',
  },
  {
    code: 'HON 350S',
    title: 'Electricity and Making',
    desc: 'A hands-on honors course where students build circuits, work with embedded systems, and connect electronics to real-world problems.',
  },
    {
    code: 'PHY 245',
    title: 'Topics in Physics: Applied Electronics and Embedded Systems',
    desc: 'A project-based course in microcontrollers, sensor integration, and embedded programming — bridging physics and engineering for students pursuing technical careers.',
  },
];

# const mentees = [
#   { name: 'Makayle Kellison', years: '2022–present', outcome: 'Ph.D. candidate in Applied Physics, Brigham Young University', award: 'Best Student Paper Award' },
#   { name: 'Evangelina Wong', years: '2019–2022', outcome: 'Ph.D. candidate in Medical Physics, Duke University', award: '' },
#   { name: 'Jack Gabriel', years: '2016–2020', outcome: 'Ph.D. in Particle Physics, College of William & Mary', award: 'Best Student Paper Award' },
#   { name: 'Lauren Schefter', years: '2023–2025', outcome: 'M.Arch., University of Virginia', award: 'Best Student Paper Award' },
#   { name: 'Connor Kaplan', years: '2019–2022', outcome: '', award: 'Best Student Paper Award' },
# ];
---

<Layout title="Teaching — Dr. Whitney L. Coyle">

  <section class="page-hero">
    <div class="container">
      <div class="page-eyebrow">Dr. Whitney L. Coyle · Rollins College</div>
      <h1 class="page-title">Teaching</h1>
      <p class="page-sub">
        Associate Professor of Physics and Chair of the Physics Department at Rollins College.
        I teach across the physics curriculum — from introductory labs to classical mechanics —
        with a focus on project-based learning, interdisciplinary connections, and undergraduate research.
      </p>
      <a href="https://www.rollins.edu/physics/" target="_blank" class="dept-badge">
        Department of Physics · Rollins College ↗
      </a>
    </div>
  </section>

  <!-- BIO SNAPSHOT -->
  <section class="section section-alt">
    <div class="container bio-grid">
      <div class="bio-text">
        <h2 class="section-title">Background</h2>
        <p class="bio-p">
          I came to physics through music. My undergraduate degree was a double major in
          Music (Clarinet Performance) and Mathematics at Murray State University — which is
          exactly how I ended up studying the acoustics of clarinets for my Ph.D. at Penn State,
          where I was an NSF Graduate Research Fellow.
        </p>
        <p class="bio-p">
          I joined Rollins College in 2015 and have built a research program that spans
          musical acoustics and rocket launch noise — two very different sound sources with
          a lot of interesting physics in common. I believe undergraduate students can and
          should do real, publishable research, and I've worked hard to make that happen here.
        </p>
      </div>
      <div class="bio-stats">
        <div class="stat-card">
          <div class="stat-num">2026</div>
          <div class="stat-label">R. Bruce Lindsay Award, Acoustical Society of America</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">Ph.D.</div>
          <div class="stat-label">Acoustics, Penn State · NSF Graduate Research Fellow</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">B.S.</div>
          <div class="stat-label">Music (Clarinet) & Mathematics, Murray State</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">2025–</div>
          <div class="stat-label">Chair, Department of Physics, Rollins College</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CURRENT COURSES -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 8px;">Current courses</h2>
      <p class="section-note">2026–Present · Rollins College</p>
      <div class="courses-grid">
        {currentCourses.map(c => (
          <div class="course-card">
            <div class="course-code">{c.code}</div>
            <div class="course-title">{c.title}</div>
            <span class={`level-badge level-${c.level.toLowerCase()}`}>{c.level}</span>
          </div>
        ))}
      </div>
      <p class="courses-note">
        For the current semester schedule, see the
        <a href="https://www.rollins.edu/physics/" target="_blank" class="inline-link">Rollins Physics Department ↗</a>
      </p>
    </div>
  </section>

  <!-- SIGNATURE COURSES -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 6px;">Signature courses</h2>
      <p class="section-note" style="margin-bottom: 24px;">Original courses conceived, designed, and developed by Dr. Coyle — from curriculum to classroom.</p>
      <div class="sig-grid">
        {signatureCourses.map(c => (
          <div class="sig-card">
            <div class="sig-code">{c.code}</div>
            <div class="sig-title">{c.title}</div>
            <p class="sig-desc">{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  # <!-- STUDENT MENTORSHIP -->
  # <section class="section">
  #   <div class="container">
  #     <h2 class="section-title" style="margin-bottom: 6px;">Undergraduate research mentorship</h2>
  #     <p class="section-note" style="margin-bottom: 24px;">
  #       Mentored students regularly present at national ASA conferences and appear as co-authors on peer-reviewed publications.
  #     </p>
  #     <div class="mentees-list">
  #       {mentees.map(m => (
  #         <div class="mentee-card">
  #           <div class="mentee-name">{m.name} <span class="mentee-years">{m.years}</span></div>
  #           {m.outcome && <div class="mentee-outcome">{m.outcome}</div>}
  #           {m.award && <span class="mentee-award">{m.award}</span>}
  #         </div>
  #       ))}
  #     </div>
  #     <p class="mentees-note">
  #       Additional researchers include: Carter Richard, Caitlin Richard, Camille Adkison,
  #       Quinn Fuse, Lucia Baquerizo, James Temple, Max Griffin, Hunter Williams,
  #       Kaylie Pasternak, Laura Mason, Nick Memmelaar, Zai Mitchell.
  #     </p>
  #   </div>
  # </section>

  <!-- CONTACT -->
  <section class="cta-strip">
    <div class="container cta-inner">
      <div>
        <div class="cta-title">Questions about courses or research?</div>
        <div class="cta-sub">Dr. Whitney L. Coyle · wcoyle@rollins.edu</div>
      </div>
      <div class="cta-btns">
        <a href="mailto:wcoyle@rollins.edu" class="btn-gold">Send an email</a>
        <a href="https://www.linkedin.com/in/wcoyle/" target="_blank" class="btn-outline">LinkedIn ↗</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero { background: var(--navy-dark); padding: 52px 0; }
  .page-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .page-title { font-size: 40px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
  .page-sub { font-size: 15px; color: rgba(255,255,255,0.6); max-width: 620px; line-height: 1.8; margin-bottom: 20px; }
  .dept-badge {
    display: inline-block; font-size: 12px; color: var(--gold);
    border: 1px solid rgba(234,160,32,0.4); padding: 6px 14px;
    border-radius: var(--radius-sm); text-decoration: none;
  }
  .dept-badge:hover { border-color: var(--gold); }

  .bio-grid { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 48px; align-items: start; }
  .bio-p { font-size: 14px; color: var(--text-muted); line-height: 1.85; margin-bottom: 16px; }
  .bio-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .stat-card { background: var(--white); border: 0.5px solid var(--border); border-radius: var(--radius-md); padding: 16px; }
  .stat-num { font-size: 18px; font-weight: 700; color: var(--navy); margin-bottom: 5px; }
  .stat-label { font-size: 11px; color: var(--text-muted); line-height: 1.5; }

  .section-note { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; }
  .courses-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 20px; }
  .course-card { background: var(--white); border: 0.5px solid var(--border); border-radius: var(--radius-md); padding: 16px; }
  .course-code { font-size: 11px; font-weight: 700; color: var(--gold-muted); letter-spacing: 0.5px; margin-bottom: 5px; }
  .course-title { font-size: 13px; font-weight: 600; color: var(--navy); margin-bottom: 8px; line-height: 1.4; }
  .level-badge {
    font-size: 10px; font-weight: 600; letter-spacing: 0.5px;
    text-transform: uppercase; padding: 2px 7px; border-radius: var(--radius-sm);
    display: inline-block;
  }
  .level-introductory { background: var(--gold-light); color: var(--gold-muted); }
  .level-intermediate  { background: #e6eeff; color: #2a44a0; }
  .level-advanced      { background: #f0e6ff; color: #5a2d91; }
  .level-honors        { background: #e6f7ef; color: #1a7a48; }
  .courses-note { font-size: 13px; color: var(--text-muted); }
  .inline-link { color: var(--navy); font-weight: 600; }
  .inline-link:hover { color: var(--gold-muted); }

  .sig-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .sig-card { background: var(--white); border: 0.5px solid var(--border); border-top: 3px solid var(--gold); border-radius: var(--radius-md); padding: 22px; }
  .sig-code { font-size: 10px; font-weight: 700; color: var(--gold-muted); letter-spacing: 1px; margin-bottom: 6px; }
  .sig-title { font-size: 14px; font-weight: 700; color: var(--navy); margin-bottom: 10px; }
  .sig-desc { font-size: 13px; color: var(--text-muted); line-height: 1.7; }

  .mentees-list { display: flex; flex-direction: column; gap: 0; margin-bottom: 20px; }
  .mentee-card { padding: 14px 0; border-bottom: 0.5px solid var(--border); }
  .mentee-card:last-child { border-bottom: none; }
  .mentee-name { font-size: 14px; font-weight: 600; color: var(--navy); margin-bottom: 3px; }
  .mentee-years { font-weight: 400; color: var(--text-muted); font-size: 12px; }
  .mentee-outcome { font-size: 13px; color: var(--text-muted); margin-bottom: 4px; }
  .mentee-award { font-size: 11px; background: var(--gold-light); color: var(--gold-muted); padding: 2px 8px; border-radius: var(--radius-sm); font-weight: 600; }
  .mentees-note { font-size: 13px; color: var(--text-muted); line-height: 1.7; font-style: italic; }

  .cta-strip { background: var(--navy); padding: 36px 0; }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
  .cta-title { font-size: 18px; font-weight: 700; color: var(--white); margin-bottom: 4px; }
  .cta-sub { font-size: 13px; color: rgba(255,255,255,0.55); }
  .cta-btns { display: flex; gap: 10px; }

  @media (max-width: 768px) {
    .page-title { font-size: 30px; }
    .bio-grid { grid-template-columns: 1fr; }
    .bio-stats { grid-template-columns: 1fr 1fr; }
    .courses-grid { grid-template-columns: 1fr 1fr; }
    .sig-grid { grid-template-columns: 1fr; }
    .cta-inner { flex-direction: column; }
  }
  @media (max-width: 480px) {
    .courses-grid { grid-template-columns: 1fr; }
    .bio-stats { grid-template-columns: 1fr; }
  }
</style>
