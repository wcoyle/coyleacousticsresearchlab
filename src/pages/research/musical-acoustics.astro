---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    title: 'Resonance and radiation in stringed instruments',
    status: 'Active',
    desc: 'Investigating how the geometry and material properties of string instruments — violins, guitars, and others — shape their acoustic radiation patterns and tonal quality.',
  },
  {
    title: 'Room acoustics of performance spaces',
    status: 'Active',
    desc: 'Measuring and modeling the acoustic properties of concert halls and rehearsal rooms, with a focus on how room geometry affects perceived clarity, warmth, and intimacy.',
  },
  {
    title: 'Psychoacoustics of musical timbre',
    status: 'Active',
    desc: 'How do listeners perceive and categorize instrument sounds? We use listening tests and acoustic analysis to understand the perceptual dimensions of timbre.',
  },
  {
    title: 'Historical instrument reconstruction',
    status: 'Completed',
    desc: 'A collaboration with the music department to acoustically characterize replicas of Baroque-era instruments and compare them with modern counterparts.',
  },
];

const pubs = [
  { title: 'Modal analysis of violin top plates using laser Doppler vibrometry', venue: 'Acta Acustica, 2025' },
  { title: 'Reverberation time measurements in small rehearsal spaces', venue: 'J. of Building Acoustics, 2024' },
];
---

<Layout title="Musical Acoustics — CARL Research">

  <section class="page-hero">
    <div class="container">
      <a href="/research" class="breadcrumb">← Research</a>
      <div class="hero-icon">🎵</div>
      <div class="page-eyebrow">Research area</div>
      <h1 class="page-title">Musical acoustics</h1>
      <p class="page-sub">
        Music and physics are deeply intertwined. We study the acoustic properties of 
        musical instruments, the design of spaces where music is performed, and the 
        psychoacoustics of how humans perceive and make meaning from sound.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 24px;">Active & past projects</h2>
      <div class="projects-list">
        {projects.map(p => (
          <div class="project-card">
            <div class="project-header">
              <h3 class="project-title">{p.title}</h3>
              <span class={`status-badge ${p.status === 'Active' ? 'status-active' : 'status-done'}`}>{p.status}</span>
            </div>
            <p class="project-desc">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 20px;">Selected publications</h2>
      {pubs.map(p => (
        <div class="pub-row">
          <div class="pub-title">{p.title}</div>
          <div class="pub-venue">{p.venue}</div>
        </div>
      ))}
      <a href="/publications" class="section-link" style="display:inline-block; margin-top: 16px;">All publications →</a>
    </div>
  </section>

  <section class="cta-strip">
    <div class="container cta-inner">
      <div>Interested in working on this research?</div>
      <a href="/join" class="btn-gold">Join the lab</a>
    </div>
  </section>

</Layout>

<style>
  .page-hero { background: var(--navy-dark); padding: 52px 0; }
  .breadcrumb { font-size: 12px; color: rgba(255,255,255,0.4); text-decoration: none; display: inline-block; margin-bottom: 20px; transition: color 0.2s; }
  .breadcrumb:hover { color: var(--gold); }
  .hero-icon { font-size: 36px; margin-bottom: 12px; }
  .page-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 10px; }
  .page-title { font-size: 40px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
  .page-sub { font-size: 15px; color: rgba(255,255,255,0.6); max-width: 580px; line-height: 1.8; }

  .projects-list { display: flex; flex-direction: column; gap: 16px; }
  .project-card { background: var(--white); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 24px; }
  .project-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; margin-bottom: 10px; }
  .project-title { font-size: 16px; font-weight: 600; color: var(--navy); line-height: 1.4; }
  .project-desc { font-size: 14px; color: var(--text-muted); line-height: 1.8; }
  .status-badge { font-size: 10px; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; padding: 3px 10px; border-radius: var(--radius-sm); white-space: nowrap; flex-shrink: 0; }
  .status-active { background: #e6f7ef; color: #1a7a48; }
  .status-done { background: var(--off-white); color: var(--text-muted); }

  .pub-row { padding: 14px 0; border-bottom: 0.5px solid var(--border); }
  .pub-row:last-of-type { border-bottom: none; }
  .pub-title { font-size: 14px; font-weight: 500; color: var(--navy); margin-bottom: 4px; }
  .pub-venue { font-size: 12px; color: var(--text-muted); font-style: italic; }

  .cta-strip { background: var(--navy); padding: 28px 0; }
  .cta-inner { display: flex; align-items: center; justify-content: space-between; font-size: 15px; color: rgba(255,255,255,0.8); font-weight: 500; }
</style>
