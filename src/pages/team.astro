---
import Layout from '../layouts/Layout.astro';

const pi = {
  initials: 'DC',
  name: 'Dr. Whitney L. Coyle',
  role: 'Principal Investigator',
  bio: 'Dr. Coyle leads the lab\'s research program, with interests in rocket acoustics, underwater sound, and machine learning for audio. [Add your full bio here.]',
  email: 'wcoyle@rollins.edu',
};

const members = [
  { initials: 'AB', name: 'Alex B.', role: 'PhD Student, yr 2', area: 'Rocket acoustics' },
  { initials: 'CM', name: 'Casey M.', role: 'MS Student', area: 'Signal processing' },
  { initials: 'JL', name: 'Jordan L.', role: 'Undergraduate researcher', area: 'Underwater acoustics' },
  { initials: 'SR', name: 'Sam R.', role: 'Undergraduate researcher', area: 'ML for audio' },
];

const alumni = [
  { name: 'Alumni Name', year: '2024', now: 'PhD program @ University of Florida' },
  { name: 'Alumni Name', year: '2023', now: 'Acoustic engineer @ SpaceX' },
];
---

<Layout title="Team — CARL">

  <section class="page-hero">
    <div class="container">
      <div class="page-eyebrow">Coyle Acoustics Research Lab</div>
      <h1 class="page-title">The team</h1>
      <p class="page-sub">Researchers, students, and collaborators working to understand the acoustic world.</p>
    </div>
  </section>

  <!-- PI -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 24px;">Principal Investigator</h2>
      <div class="pi-card">
        <div class="pi-avatar">{pi.initials}</div>
        <div class="pi-info">
          <div class="pi-name">{pi.name}</div>
          <div class="pi-role">{pi.role}</div>
          <p class="pi-bio">{pi.bio}</p>
          <a href={`mailto:${pi.email}`} class="btn-navy" style="margin-top: 16px;">{pi.email}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CURRENT MEMBERS -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 24px;">Current members</h2>
      <div class="member-grid">
        {members.map(m => (
          <div class="member-card">
            <div class="member-avatar">{m.initials}</div>
            <div class="member-name">{m.name}</div>
            <div class="member-role">{m.role}</div>
            <div class="member-area">{m.area}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ALUMNI -->
  <section class="section section-alt">
    <div class="container">
      <h2 class="section-title" style="margin-bottom: 20px;">Alumni</h2>
      <div class="alumni-list">
        {alumni.map(a => (
          <div class="alumni-item">
            <div class="alumni-name">{a.name} <span class="alumni-year">({a.year})</span></div>
            <div class="alumni-now">{a.now}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-hero { background: var(--navy-dark); padding: 52px 0; }
  .page-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .page-title { font-size: 40px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
  .page-sub { font-size: 15px; color: rgba(255,255,255,0.6); max-width: 480px; line-height: 1.75; }

  .pi-card { display: flex; gap: 28px; align-items: flex-start; background: var(--white); border: 0.5px solid var(--border); border-top: 3px solid var(--gold); border-radius: var(--radius-md); padding: 28px; }
  .pi-avatar { width: 72px; height: 72px; border-radius: 50%; background: var(--navy); display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 700; color: var(--gold); border: 2px solid var(--gold); flex-shrink: 0; }
  .pi-name { font-size: 18px; font-weight: 700; color: var(--navy); }
  .pi-role { font-size: 12px; color: var(--text-muted); margin-top: 2px; margin-bottom: 12px; }
  .pi-bio { font-size: 14px; color: var(--text-muted); line-height: 1.75; }

  .member-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .member-card { background: var(--white); border: 0.5px solid var(--border); border-radius: var(--radius-lg); padding: 22px; text-align: center; }
  .member-avatar { width: 52px; height: 52px; border-radius: 50%; background: var(--navy); display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; font-size: 14px; font-weight: 700; color: var(--gold); border: 2px solid var(--gold); }
  .member-name { font-size: 14px; font-weight: 600; color: var(--navy); }
  .member-role { font-size: 11px; color: var(--text-muted); margin-top: 3px; }
  .member-area { font-size: 11px; color: var(--gold-muted); margin-top: 6px; font-style: italic; }

  .alumni-list { display: flex; flex-direction: column; gap: 0; }
  .alumni-item { padding: 14px 0; border-bottom: 0.5px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
  .alumni-item:last-child { border-bottom: none; }
  .alumni-name { font-size: 14px; font-weight: 600; color: var(--navy); }
  .alumni-year { font-weight: 400; color: var(--text-muted); }
  .alumni-now { font-size: 13px; color: var(--text-muted); }
</style>

<style>
  @media (max-width: 768px) {
    .page-title { font-size: 30px; }
    .pi-card { flex-direction: column; }
    .member-grid { grid-template-columns: 1fr 1fr; }
    .alumni-item { flex-direction: column; align-items: flex-start; gap: 4px; }
  }
</style>
