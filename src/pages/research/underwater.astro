---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Research — CARL">
  <section style="background: var(--navy-dark); padding: 52px 0;">
    <div class="container">
      <a href="/research" style="font-size: 12px; color: rgba(255,255,255,0.4); text-decoration: none; display: inline-block; margin-bottom: 20px;">← Research</a>
      <h1 style="font-size: 40px; font-weight: 700; color: var(--white); margin-bottom: 14px;">
        Underwater sound
      </h1>
      <p style="font-size: 15px; color: rgba(255,255,255,0.6); max-width: 520px; line-height: 1.8;">
        This page is a placeholder — replace with your real project descriptions.
      </p>
    </div>
  </section>
  <section class="section section-alt">
    <div class="container">
      <p style="color: var(--text-muted); font-size: 14px;">Project details coming soon. <a href="/research" style="color: var(--navy);">← Back to research overview</a></p>
    </div>
  </section>
</Layout>
