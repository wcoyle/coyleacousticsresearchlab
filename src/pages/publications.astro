---
import Layout from '../layouts/Layout.astro';

const journalArticles = [
  {
    authors: 'Coyle, W.L., Schefter, L.K.*, Cannaday, A.E., Griffin, M.*, & Rokni, E.',
    year: '2025',
    title: 'Comparing classical and empirical end correction models using spatial pressure measurements in flue pipes.',
    venue: 'Acta Acustica, 9, 71.',
    doi: 'https://doi.org/10.1051/aacus/2025058',
  },
  {
    authors: 'Moore, T.R., Kellison, M.S.*, Coyle, W.L.',
    year: '2023',
    title: 'TESPI and visualizing flow in and around open pipes.',
    venue: 'JASA Express Letters.',
    doi: 'https://doi.org/10.1121/10.0019500',
  },
  {
    authors: 'Gee, K.L., Hart, G.W., Cunningham, C.F., Anderson, M.C., Bassett, M.S., Mathews, L.T., Durrant, J.T., Moats, L.T., Coyle, W.L., Kellison, M.S.*, & Kuffskie, M.J.*',
    year: '2023',
    title: 'Space Launch System acoustics: Far-field noise measurements of the Artemis-I launch.',
    venue: 'JASA Express Letters.',
    doi: 'https://doi.org/10.1121/10.0017571',
  },
  {
    authors: 'Coyle, W.L., Wong, E.Y.*, Gabriel, J.D.*, Kaplan, C.N.*',
    year: '2021',
    title: 'Computational determination of transition times using measured mouthpiece pressure.',
    venue: 'JASA Express Letters.',
    doi: 'https://doi.org/10.1121/10.0005352',
  },
  {
    authors: 'Coyle, W.L., Gabriel, J.D.*',
    year: '2019',
    title: 'Automatic detection of tongued and slurred note transitions in clarinet playing.',
    venue: 'Journal of the Acoustical Society of America, 146(3).',
    doi: 'https://doi.org/10.1121/1.5127848',
  },
  {
    authors: 'Coyle, W.L., Guillemain, P., Kergomard, J., & Dalmont, J.P.',
    year: '2015',
    title: 'Predicting playing frequencies for clarinets: comparison between numerical simulations and analytic formulas.',
    venue: 'Journal of the Acoustical Society of America, 138.',
    doi: 'https://doi.org/10.1121/1.4935360',
  },
];

const proceedings = [
  {
    authors: 'Williams, H.N.*, Coyle, W.L., & Gee, K.L.',
    year: '2025',
    title: 'Using RUMBLE for spaceport community noise prediction.',
    venue: 'Proceedings of Meetings on Acoustics. Hawaii',
    doi: null,
  },
  {
    authors: 'Griffin, M.*, Coyle, W.L., & Pàmies-Vilà, M.',
    year: '2025',
    title: 'Automated detection of legato transitions.',
    venue: 'Proceedings of Meetings on Acoustics (ISMA). New Orleans',
    doi: null,
  },
  {
    authors: 'Schefter, L.K.*, Coyle, W.L., Rokni, E., & Cannaday, A.',
    year: '2024',
    title: 'Measuring acoustic standing wave behavior in a flue pipe.',
    venue: 'Proceedings of Meetings on Acoustics. Ottawa',
    doi: null,
  },
  {
    authors: 'Kellison, M.*, Gee, K.L., Coyle, W.L.',
    year: '2024',
    title: 'Aeroacoustic analysis of NASA\'s Space Launch System Artemis-I mission.',
    venue: 'AIAA.',
    doi: 'https://doi.org/10.2514/6.2024-3033',
  },
];

const other = [
  {
    authors: 'Coyle, W.L.',
    year: '2024',
    title: 'Neville Fletcher\'s vibrant valve voyage.',
    venue: 'Journal of the Acoustical Society of America, 156(5).',
    doi: 'https://doi.org/10.1121/10.0034226',
  },
  {
    authors: 'Fuse, C., Cannaday, A., & Coyle, W.L.',
    year: '2020',
    title: 'Undergraduate research at a liberal arts college during a time of disruption.',
    venue: 'SPUR.',
    doi: null,
  },
];

const inProgress = [
  {
    authors: 'Coyle, W.L., et al.',
    title: 'Community-scale measurements of acoustic, ground, and structural response during rocket launches.',
    venue: 'Submitted to JASA Express Letters. April 2026',
  },
  {
    authors: 'Coyle, W.L., Gee, K.L., Kellison, M.S.*, & Williams, H.R.*',
    title: 'An application of aircraft noise metrics to the Artemis-I launch.',
    venue: 'Journal of the Acoustical Society of America. In preparation.',
  },
];
---

<Layout title="Publications — CARL">

  <section class="page-hero">
    <div class="container">
      <div class="page-eyebrow">Dr. Whitney L. Coyle</div>
      <h1 class="page-title">Publications</h1>
      <p class="page-sub">
        Peer-reviewed articles, conference proceedings, and works in progress.
        Asterisk (*) denotes undergraduate co-author.
      </p>
      <a href="https://orcid.org/0000-0002-2161-4584" target="_blank" class="orcid-badge">
        ORCID ↗
      </a>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">

      <!-- WORKS IN PROGRESS -->
      <div class="pub-group">
        <h2 class="group-title">Works in progress</h2>
        {inProgress.map(p => (
          <div class="pub-card in-progress">
            <div class="pub-meta">{p.authors}</div>
            <div class="pub-title">{p.title}</div>
            <div class="pub-venue">{p.venue}</div>
          </div>
        ))}
      </div>

      <!-- JOURNAL ARTICLES -->
      <div class="pub-group">
        <h2 class="group-title">Peer-reviewed journal articles</h2>
        {journalArticles.map(p => (
          <div class="pub-card">
            <div class="pub-row">
              <div class="pub-year">{p.year}</div>
              <div class="pub-body">
                <div class="pub-meta">{p.authors}</div>
                <div class="pub-title">{p.title}</div>
                <div class="pub-venue">{p.venue}</div>
              </div>
              {p.doi && <a href={p.doi} target="_blank" class="pub-doi">DOI ↗</a>}
            </div>
          </div>
        ))}
      </div>

      <!-- CONFERENCE PROCEEDINGS -->
      <div class="pub-group">
        <h2 class="group-title">Conference proceedings</h2>
        {proceedings.map(p => (
          <div class="pub-card">
            <div class="pub-row">
              <div class="pub-year">{p.year}</div>
              <div class="pub-body">
                <div class="pub-meta">{p.authors}</div>
                <div class="pub-title">{p.title}</div>
                <div class="pub-venue">{p.venue}</div>
              </div>
              {p.doi && <a href={p.doi} target="_blank" class="pub-doi">DOI ↗</a>}
            </div>
          </div>
        ))}
      </div>

      <!-- OTHER -->
      <div class="pub-group">
        <h2 class="group-title">Other publications</h2>
        {other.map(p => (
          <div class="pub-card">
            <div class="pub-row">
              <div class="pub-year">{p.year}</div>
              <div class="pub-body">
                <div class="pub-meta">{p.authors}</div>
                <div class="pub-title">{p.title}</div>
                <div class="pub-venue">{p.venue}</div>
              </div>
              {p.doi && <a href={p.doi} target="_blank" class="pub-doi">DOI ↗</a>}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

</Layout>

<style>
  .page-hero { background: var(--navy-dark); padding: 52px 0; }
  .page-eyebrow { font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 12px; }
  .page-title { font-size: 40px; font-weight: 700; color: var(--white); margin-bottom: 14px; }
  .page-sub { font-size: 15px; color: rgba(255,255,255,0.6); max-width: 560px; line-height: 1.75; margin-bottom: 20px; }
  .orcid-badge {
    display: inline-block; font-size: 12px; color: var(--gold);
    border: 1px solid rgba(234,160,32,0.4); padding: 6px 14px;
    border-radius: var(--radius-sm); text-decoration: none;
  }
  .orcid-badge:hover { border-color: var(--gold); }

  .pub-group { margin-bottom: 48px; }
  .group-title {
    font-size: 13px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--gold-muted);
    border-bottom: 0.5px solid var(--border);
    padding-bottom: 10px; margin-bottom: 16px;
  }

  .pub-card {
    background: var(--white); border: 0.5px solid var(--border);
    border-radius: var(--radius-md); padding: 18px 22px; margin-bottom: 10px;
  }
  .pub-card.in-progress { border-left: 3px solid var(--gold); }

  .pub-row { display: flex; gap: 16px; align-items: flex-start; }
  .pub-year { font-size: 12px; font-weight: 700; color: var(--gold-muted); min-width: 38px; padding-top: 2px; }
  .pub-body { flex: 1; }
  .pub-meta { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
  .pub-title { font-size: 14px; font-weight: 600; color: var(--navy); margin-bottom: 4px; line-height: 1.45; }
  .pub-venue { font-size: 12px; color: var(--text-muted); font-style: italic; }
  .pub-doi {
    font-size: 11px; font-weight: 700; color: var(--navy);
    text-decoration: none; flex-shrink: 0; padding-top: 2px;
    white-space: nowrap;
  }
  .pub-doi:hover { color: var(--gold-muted); }

  @media (max-width: 768px) {
    .page-title { font-size: 30px; }
    .pub-row { flex-wrap: wrap; }
    .pub-year { min-width: auto; }
  }
  .press-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .press-card {
    background: var(--white); border: 0.5px solid var(--border);
    border-left: 3px solid var(--navy); border-radius: 0 var(--radius-md) var(--radius-md) 0;
    padding: 20px; text-decoration: none; display: flex; flex-direction: column; gap: 10px;
    transition: border-left-color 0.15s;
  }
  .press-card:hover { border-left-color: var(--gold); }
  .press-outlet { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; color: var(--gold-muted); }
  .press-title { font-size: 14px; font-weight: 600; color: var(--navy); line-height: 1.45; flex: 1; }
  .press-cta { font-size: 12px; font-weight: 700; color: var(--text-muted); }
</style>
